---
import { getCollection, getEntry, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("archive", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
  }));
}

const { slug } = Astro.params;
if (!slug) {
  throw new Error("Missing archive slug.");
}

const entry = await getEntry("archive", slug);
if (!entry) {
  throw new Error(`Archive entry not found: ${slug}`);
}

const { Content } = await render(entry);
---

<MainLayout
  title={`${entry.data.title} | Archive`}
  description={entry.data.description}
  toc={[{ label: "Article", href: "#article" }]}
>
  <article id="article" class="glass-card content-prose p-7 md:p-9">
    <p class="premium-kicker">{entry.data.publishedAt.toDateString()}</p>
    <h1 class="mt-4 max-w-4xl text-4xl font-semibold text-zinc-50 md:text-[2.85rem]">{entry.data.title}</h1>
    <p class="mt-4 max-w-3xl text-zinc-300">{entry.data.description}</p>
    <div class="mt-8 rounded-2xl border border-white/10 bg-white/[0.035] p-5 md:p-7">
      <Content />
    </div>
  </article>
</MainLayout>
