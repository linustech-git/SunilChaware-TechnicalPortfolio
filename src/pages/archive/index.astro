---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

const allEntries = await getCollection("archive", ({ data }) => !data.draft);
const entries = allEntries.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const mediumArticles = [
  {
    title: "Prododo: Your Product Management with Dodo Payments Made Easy",
    date: "Apr 13, 2026",
    href: "https://medium.com/@linustech/prododo-your-product-management-with-dodo-payments-made-easy-cbe454f7095d",
    checksum: "md.cbe454",
  },
  {
    title: "Why did I create TaskProcessor library?",
    date: "Mar 25, 2026",
    href: "https://medium.com/@linustech/why-did-i-create-taskprocessor-nuget-e49ab07b43d6",
    checksum: "md.e49ab0",
  },
  {
    title: "Why Developers Should Understand Business: A Strategic Advantage in Tech",
    date: "Aug 10, 2025",
    href: "https://medium.com/@linustech/why-developers-should-understand-business-a-strategic-advantage-in-tech-8ff40de74df4",
    checksum: "md.8ff40d",
  },
  {
    title: "How we used multi-threading in .Net",
    date: "Jul 23, 2025",
    href: "https://medium.com/@linustech/how-we-used-multi-threading-in-net-cd2ddf5e45ad",
    checksum: "md.cd2ddf",
  },
  {
    title: "Quantum Computing: A way ahead",
    date: "Jul 17, 2025",
    href: "https://medium.com/@linustech/quantum-computing-a-way-ahead-b2f7b1c566f7",
    checksum: "md.b2f7b1",
  },
];
---

<MainLayout
  title="Archive | SunilChaware"
  description="Technical archive of architecture notes and engineering insights."
  toc={[
    { label: "All Insights", href: "#all-insights" },
    { label: "External Publications", href: "#external-publications" },
  ]}
>
  <section id="all-insights" class="glass-card p-7 md:p-9">
    <p class="premium-kicker">Writing and Notes</p>
    <h1 class="mt-4 text-4xl font-semibold text-zinc-50 md:text-[2.85rem]">Archive</h1>
    <p class="mt-4 max-w-3xl text-zinc-300">A chronological index of technical whitepapers, patterns, and operational insights.</p>

    <ul class="mt-6 space-y-4">
      {entries.map((entry, idx) => (
        <li>
          <a class="group hover-expand relative block rounded-lg border border-white/10 bg-white/[0.028] p-5 shadow-xl shadow-black/10 transition hover:border-cyan-200/25 hover:bg-white/[0.052]" href={`/archive/${entry.id}`}>
            <span class="checksum-tag">rev.{String(idx + 12).padStart(3, "0")}</span>
            <p class="text-sm text-zinc-400">{entry.data.publishedAt.toLocaleDateString()}</p>
            <h2 class="mt-1 text-lg font-semibold text-zinc-50 group-hover:text-cyan-100">{entry.data.title}</h2>
            <p class="mt-1 text-sm text-zinc-400">{entry.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section id="external-publications" class="mt-10 glass-card p-7 md:p-9">
    <details class="mt-3 group" open>
      <summary class="hover-expand block cursor-pointer list-none rounded-lg border border-white/10 bg-white/[0.028] p-5">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-2xl font-semibold text-zinc-100">Medium Writing</p>
            <p class="mt-2 text-zinc-400">Long-form technical notes, architecture ideas, and implementation learnings.</p>
          </div>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="mt-1 h-5 w-5 flex-shrink-0 text-zinc-500 transition group-open:rotate-90">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </div>
      </summary>

      <ul class="mt-5 space-y-3">
        {mediumArticles.map((article) => (
          <li>
            <a
              href={article.href}
              target="_blank"
              rel="noreferrer"
              class="group hover-expand relative block rounded-lg border border-white/10 bg-white/[0.028] p-4 shadow-xl shadow-black/10 transition hover:border-cyan-200/25 hover:bg-white/[0.052]"
            >
              <span class="checksum-tag">{article.checksum}</span>
              <p class="font-mono text-xs text-zinc-500">{article.date}</p>
              <p class="mt-1 text-base font-semibold text-zinc-50 group-hover:text-cyan-100">{article.title}</p>
            </a>
          </li>
        ))}
      </ul>
    </details>
  </section>
</MainLayout>
