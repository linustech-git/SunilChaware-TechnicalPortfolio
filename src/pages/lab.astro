---
import MainLayout from "../layouts/MainLayout.astro";
import Card from "../components/shared/Card.astro";

const toc = [
  { label: "Lab Charter", href: "#charter" },
  { label: "NuGet Library", href: "#nuget-library" },
  { label: "Experiments", href: "#experiments" },
];
---

<MainLayout title="Lab | SunilChaware" description="Code snippets and live engineering experiments." toc={toc}>
  <section id="charter" class="glass-card p-7 md:p-9">
    <p class="premium-kicker">Engineering Notebook</p>
    <h1 class="page-title mt-4">Lab</h1>
    <p class="mt-4 max-w-3xl text-zinc-300">
      A working notebook for prototyping ideas before they are productionized in Numerinus.
    </p>
  </section>

  <section id="nuget-library" class="mt-10 glass-card p-7 md:p-9">
    <h2 class="section-title">NuGet Package Library</h2>
    <p class="mt-4 max-w-3xl text-zinc-300">
      Explore my NuGet package work here:
      <a
        href="https://www.nuget.org/profiles/LinusTech"
        target="_blank"
        rel="noreferrer"
        class="ml-1 font-semibold text-cyan-200 hover:text-white"
      >
        LinusTech NuGet Profile
      </a>
      .
    </p>
    <p class="mt-4 max-w-3xl rounded-lg border border-white/10 bg-white/[0.028] p-4 text-zinc-300">
      A dedicated storefront for Numerinus NuGet packages is coming soon.
    </p>
  </section>
  
  <section id="experiments" class="mt-10 glass-card p-7 md:p-9">
    <h2 class="section-title">ProDodo</h2>
    <p class="mt-4 max-w-3xl text-zinc-300">
      Explore my open source repo for product management on dodo payments here:
      <a
        href="https://github.com/linustech-git/ProDodo"
        target="_blank"
        rel="noreferrer"
        class="ml-1 font-semibold text-cyan-200 hover:text-white"
      >
        ProDodo
      </a>
      .
    </p>
    <p class="mt-4 max-w-3xl rounded-lg border border-white/10 bg-white/[0.028] p-4 text-zinc-300">
      A console application for programatically managing your products on dodo payments.
    </p>
  </section>

</MainLayout>
