---
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/shared/Button.astro";

const toc = [
  { label: "About", href: "#about" },
  { label: "Technical Skills", href: "#technical-skills" },
  { label: "How I Work", href: "#how-i-work" },
  { label: "What I Value", href: "#what-i-value" },
];

const skillGroups = [
  {
    label: "Frontend",
    bg: "/images/skills/frontend.svg",
    items: ["React", "Angular", "JavaScript", "TypeScript", "Astro"],
  },
  {
    label: "Backend",
    bg: "/images/skills/backend.svg",
    items: ["C#", ".NET Core", "Web API", "Minimum APIs", "LINQ", "Dapper", "Entity Framework"],
  },
  {
    label: "Database",
    bg: "/images/skills/database.svg",
    items: ["SQL Server", "Evolve DB", "PostgreSQL"],
  },
  {
    label: "Cloud & DevOps",
    bg: "/images/skills/cloud-devops.svg",
    items: [
      "Azure DevOps",
      "Azure Portal (AZ-900 certified)",
      "CI/CD Pipelines",
      "Kiuwan",
      "Docker",
      "Kubernetes",
      "Railway",
      "Github Actions"
    ],
  },
  {
    label: "Architecture",
    bg: "/images/skills/architecture.svg",
    items: ["Microservices", "REST APIs", "Event-Driven Architecture", "CQRS", "Design Patterns"],
  },
  {
    label: "Artificial intelligence",
    bg: "/images/skills/ai.svg",
    items: ["AI agent integration", "RAG"],
  },
  {
    label: "Security",
    bg: "/images/skills/security.svg",
    items: ["SSO", "MFA", "Machine fingerprinting", "RBAC", "OAuth 2.0"],
  },
  {
    label: "Tools",
    bg: "/images/skills/tools.svg",
    items: [
      "VS Code",
      "Visual Studio",
      "Cursor",
      "Postman",
      "Swagger",
      "Git",
      "GitHub Copilot",
      "Azure function",
      "Service bus and Event Hub",
    ],
  },
];
---

<MainLayout
  title="About | SunilChaware"
  description="About Sunil Chaware: engineer, product builder, and lifelong learner."
  toc={toc}
>
  <section id="about" class="glass-card p-7 md:p-10">
    <p class="premium-kicker">About Sunil</p>
    <h1 class="mt-4 max-w-4xl text-3xl font-semibold leading-tight text-zinc-50 md:text-[2.75rem]">
      I build products where deep engineering meets practical value.
    </h1>
    <div class="mt-6 max-w-3xl space-y-5 text-base leading-relaxed text-zinc-300 md:text-[1.02rem]">
      <p>
        I am Sunil, an engineer who enjoys turning complex ideas into useful products. I like technology not only for
        what it can do, but for what it can simplify. Right now, I am building Numerinus, a .NET math library, and a
        storefront around it. That combination matters to me because I care about both sides of engineering: creating
        a powerful core and making it easy for people to discover, understand, and trust what they are using.
      </p>
      <p>
        My mindset is shaped by curiosity. I spend a lot of time exploring architecture, performance, developer
        experience, and product clarity. I enjoy the details: naming, API ergonomics, error behavior, and the little
        interaction choices that make software feel reliable. I keep learning through experiments, writing, rebuilding,
        and shipping. Every iteration teaches me something, and I try to convert that learning into cleaner systems and
        better decisions.
      </p>
      <p>
        I do not see engineering as just code delivery. For me, it is a craft with responsibility. Build with
        precision. Communicate with clarity. Design with empathy for both users and developers. Leave systems more
        stable, understandable, and future-ready than they were before. That is the standard I hold for my work, and
        the direction I want Numerinus to represent.
      </p>
      <p>
        I am also energized by leadership through execution: mentoring developers, improving engineering practices, and
        helping teams move from ambiguity to shippable outcomes. The balance I value most is this: think strategically,
        execute practically, and keep the product experience as strong as the technical foundation behind it.
      </p>
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <Button href="/Sunil-Chaware-CV.pdf" label="Download CV" variant="ghost" newTab={true} className="w-40" icon="download" />
      <Button
        href="https://www.linkedin.com/in/sunil-chaware-9035a646/"
        label="LinkedIn"
        variant="ghost"
        newTab={true}
        icon="linkedin"
        className="w-40"
      />
      <Button
        href="https://github.com/linustech-git"
        label="GitHub"
        variant="ghost"
        newTab={true}
        icon="github"
        className="w-40"
      />
      <Button
        href="https://medium.com/@linustech"
        label="Medium"
        variant="ghost"
        newTab={true}
        icon="medium"
        className="w-40"
      />
    </div>
  </section>

  <section id="technical-skills" class="mt-10 glass-card p-7 md:p-10">
    <div class="flex flex-col gap-4 border-b border-white/10 pb-6 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-zinc-500">Capability stack</p>
        <h2 class="mt-2 text-2xl font-semibold md:text-[1.65rem]">Technical Skills</h2>
        <p class="mt-3 text-sm leading-relaxed text-zinc-500 md:text-[0.95rem]">
          A concise map of the technologies, platforms, and patterns I use to design and ship production systems.
        </p>
      </div>
      <p class="shrink-0 font-mono text-xs text-zinc-600 md:text-right">
        <span class="text-cyan-200/80">{String(skillGroups.length).padStart(2, "0")}</span>
        <span class="text-zinc-600"> / </span>
        <span class="text-zinc-500">domains</span>
      </p>
    </div>

    <dl class="mt-8 grid gap-5 sm:grid-cols-2">
      {
        skillGroups.map((group, idx) => (
          <div class="group relative overflow-hidden rounded-lg border border-white/10 bg-zinc-950/55 p-5 shadow-xl shadow-black/10 transition hover:border-cyan-200/25 hover:bg-zinc-950/75">
            <img
              src={group.bg}
              alt=""
              width="400"
              height="240"
              class="pointer-events-none absolute inset-0 z-0 h-full w-full object-contain object-right p-1 opacity-[0.82] brightness-125 saturate-110 transition-opacity duration-300 group-hover:opacity-[0.95] md:opacity-[0.72] md:group-hover:opacity-[0.9]"
              loading="lazy"
              decoding="async"
            />
            <div
              class="pointer-events-none absolute inset-0 z-[1] bg-gradient-to-r from-zinc-950 from-[18%] via-zinc-950/70 via-[48%] to-transparent"
              aria-hidden="true"
            />
            <span
              class="pointer-events-none absolute left-0 top-5 z-[2] h-12 w-0.5 bg-gradient-to-b from-cyan-200/90 to-cyan-300/20 opacity-90 transition group-hover:from-white group-hover:to-cyan-300/30"
              aria-hidden="true"
            />
            <div class="relative z-[3] pl-3">
              <dt class="flex items-baseline justify-between gap-3">
                <span class="font-mono text-sm font-semibold uppercase tracking-[0.14em] text-cyan-200/90 md:text-base">
                  {group.label}
                </span>
                <span class="font-mono text-xs text-zinc-600 tabular-nums md:text-sm">
                  {String(idx + 1).padStart(2, "0")}
                </span>
              </dt>
              <dd class="mt-3 text-sm leading-relaxed text-zinc-400 md:text-[0.95rem]">
                <span class="sr-only">{group.items.join(", ")}</span>
                <span aria-hidden="true" class="flex flex-wrap gap-2">
                  {group.items.map((item) => (
                    <span class="rounded-full border border-white/10 bg-white/[0.055] px-2.5 py-1 text-xs text-zinc-300">
                      {item}
                    </span>
                  ))}
                </span>
              </dd>
            </div>
          </div>
        ))
      }
    </dl>
  </section>


</MainLayout>
