---
import MainLayout from "../layouts/MainLayout.astro";
import Card from "../components/shared/Card.astro";

const toc = [
  { label: "Projects Overview", href: "#overview" },
  { label: "My Own Projects", href: "#my-own-projects" },
  { label: "Company Projects", href: "#company-projects" },
];
---

<MainLayout title="Workspace | Numerinus" description="Numerinus workspace and tool-suite overview." toc={toc}>
  <section id="overview" class="glass-card p-7 md:p-9">
    <p class="premium-kicker">Selected Work</p>
    <h1 class="mt-4 text-4xl font-semibold text-zinc-50 md:text-[2.85rem]">My Projects</h1>
    <p class="mt-4 max-w-3xl text-zinc-300">
      A curated view of products, platforms, and technical initiatives I have built and shipped.
    </p>
  </section>

  <section id="my-own-projects" class="mt-10 glass-card p-6 md:p-8">
    <details class="group" open>
      <summary class="hover-expand block cursor-pointer list-none rounded-lg border border-white/10 bg-white/[0.028] p-5">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-2xl font-semibold text-zinc-100">My Own Projects</p>
            <p class="mt-2 text-zinc-400">Independent builds, product experiments, and library-driven platforms.</p>
          </div>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="mt-1 h-5 w-5 flex-shrink-0 text-zinc-500 transition group-open:rotate-90">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </div>
      </summary>
      <div class="mt-4 grid gap-6 md:grid-cols-2">
        <Card
          className="group hover-expand md:col-span-2"
          title="Numerinus"
          description="A financial computation ecosystem for .NET teams."
        >
          <div class="flex flex-col gap-5 md:flex-row md:items-start">
            <img
              src="/images/projects/numerinus-logo.png"
              alt="Numerinus logo"
              class="w-full rounded-lg border border-white/10 object-cover md:w-56 md:flex-shrink-0"
            />
            <div>
              <p class="text-sm leading-relaxed text-zinc-400">
                Architected and developed a production-grade, high-performance financial computation library for .NET,
                supported by a complete product platform for licensing, telemetry, validation, and administration.
              </p>
              <ul class="mt-4 space-y-2 text-sm leading-relaxed text-zinc-400">
                <li>
                  <span class="text-zinc-300">URLs:</span>
                  <a href="https://test.numerinus.dev/" target="_blank" rel="noreferrer" class="font-semibold text-cyan-200 hover:text-white">Test env</a>
                  <span class="text-zinc-600"> | </span>
                  <a href="https://numerinus.dev/" target="_blank" rel="noreferrer" class="font-semibold text-cyan-200 hover:text-white">Production coming soon</a>
                </li>
                <li>
                  <span class="text-zinc-300">Stack:</span> React.js, TanStack, .NET Core minimum APIs, PostgreSQL, and Entity Framework.
                </li>
                <li>
                  <span class="text-zinc-300">Loan modeling:</span> EMI, amortization, prepayments, and a tiered pricing model for real-world lending scenarios.
                </li>
                <li>
                  <span class="text-zinc-300">Platform:</span> full licensing, validation, and telemetry layer across API and SDK, turning Numerinus into an ecosystem.
                </li>
                <li>
                  <span class="text-zinc-300">Admin:</span> a thorough dashboard to monitor required operational, licensing, and usage parameters.
                </li>
              </ul>
              <p class="mt-3 font-mono text-xs text-zinc-500">Status: Test environment live, production coming soon</p>
              <div class="mt-4 flex flex-wrap gap-3">
                <a
                  href="https://test.numerinus.dev/"
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex rounded-lg border border-cyan-200/35 bg-cyan-200/10 px-3 py-2 text-sm font-semibold text-cyan-100 transition hover:border-cyan-100/70 hover:bg-cyan-200/15"
                >
                  Open test environment
                </a>
                <a
                  href="https://numerinus.dev/"
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex rounded-lg border border-white/10 bg-white/[0.028] px-3 py-2 text-sm font-semibold text-zinc-200 transition hover:border-cyan-200/35 hover:text-cyan-100"
                >
                  Production coming soon
                </a>
              </div>
            </div>
          </div>
        </Card>

        <Card
          className="group hover-expand md:col-span-2"
          title="TaskProcessor (.NET Library)"
          description="A lightweight concurrency utility for controlled parallel execution in backend systems."
        >
          <div class="flex flex-col gap-5 md:flex-row md:items-start">
            <img
              src="/images/projects/taskprocessor.png"
              alt="TaskProcessor"
              class="w-full rounded-lg border border-zinc-800 object-cover md:w-48 md:flex-shrink-0"
            />
            <div>
              <p class="text-sm text-zinc-400">
                Built to solve instability caused by uncontrolled `Task.WhenAll` usage in high-volume workloads.
                TaskProcessor introduces controlled parallelism, retry policies, and failure handling without polluting business
                logic.
              </p>
              <p class="mt-3 text-sm text-zinc-400">
                Supports both execution and transformation modes, making it usable for ETL, background jobs, API workloads,
                and bulk processing pipelines.
              </p>
              <p class="mt-3 font-mono text-xs text-zinc-500">Published: Mar 25, 2026</p>
              <a
                href="https://medium.com/@linustech/why-did-i-create-taskprocessor-nuget-e49ab07b43d6"
                target="_blank"
                rel="noreferrer"
                class="mt-3 inline-flex text-sm font-semibold text-cyan-200 hover:text-white"
              >
                Read project article
              </a>
            </div>
          </div>
        </Card>
      </div>
    </details>

  </section>

  <section id="company-projects" class="mt-10 glass-card p-6 md:p-8">
    <details class="group" open>
      <summary class="hover-expand block cursor-pointer list-none rounded-lg border border-white/10 bg-white/[0.028] p-5">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-2xl font-semibold text-zinc-100">Company Projects</p>
            <p class="mt-2 text-zinc-400">Enterprise systems delivered across EdTech, construction, and fintech domains.</p>
          </div>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="mt-1 h-5 w-5 flex-shrink-0 text-zinc-500 transition group-open:rotate-90">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </div>
      </summary>
      <a
        href="https://www.linkedin.com/in/sunil-chaware-9035a646/"
        target="_blank"
        rel="noreferrer"
        class="mt-4 inline-flex text-sm font-semibold text-cyan-200 hover:text-white"
      >
        View full LinkedIn profile
      </a>
      <div class="mt-5 grid gap-6">
        <Card
          className="group hover-expand"
          title="SIMS Nextgen (ParentPay Group)"
          description="Enterprise SaaS platform modernization for school systems."
        >
          <div class="flex flex-col gap-5 md:flex-row md:items-start">
            <img
              src="/images/projects/sims-nextgen.png"
              alt="SIMS Nextgen"
              class="w-full rounded-lg border border-zinc-800 object-cover md:w-44 md:flex-shrink-0"
            />
            <div>
              <p class="text-sm leading-relaxed text-zinc-400">
                Led delivery for the Exams domain on the Nextgen platform, from architecture decisions to production release.
              </p>
              <ul class="mt-4 space-y-2 text-sm leading-relaxed text-zinc-400">
                <li><span class="text-zinc-300">Scope:</span> DEX migration pipeline, legacy writeback flow, and module APIs.</li>
                <li><span class="text-zinc-300">Ownership:</span> repository setup, schema planning, and release readiness.</li>
                <li><span class="text-zinc-300">Outcome:</span> enabled stable delivery path for core school workflows.</li>
              </ul>
              <p class="mt-3 font-mono text-xs text-zinc-500">Jul 2025 - Present</p>
            </div>
          </div>
        </Card>

        <Card
          className="group hover-expand"
          title="SpecLink Cloud"
          description="Construction specification software for architects, contractors, and construction companies."
        >
          <div class="flex flex-col gap-5 md:flex-row md:items-start">
            <img
              src="/images/projects/speclink.png"
              alt="RIB SpecLink"
              class="w-full rounded-lg border border-zinc-800 bg-white object-cover md:w-44 md:flex-shrink-0"
            />
            <div>
              <p class="text-sm leading-relaxed text-zinc-400">
                Helped evolve a large SaaS platform into a more scalable and maintainable architecture.
              </p>
              <ul class="mt-4 space-y-2 text-sm leading-relaxed text-zinc-400">
                <li><span class="text-zinc-300">Stack:</span> Angular, .NET Core, SQL Server, Azure DevOps.</li>
                <li><span class="text-zinc-300">Execution:</span> extracted heavy workflows into dedicated microservices.</li>
                <li><span class="text-zinc-300">Impact:</span> improved performance and reduced release friction.</li>
              </ul>
              <p class="mt-3 font-mono text-xs text-zinc-500">Apr 2022 - Jul 2025</p>
            </div>
          </div>
        </Card>

        <Card
          className="group hover-expand"
          title="Terrace Finance Corporation"
          description="Enterprise SaaS multi-lender platform."
        >
          <div class="flex flex-col gap-5 md:flex-row md:items-start">
            <img
              src="/images/projects/terrace-finance.png"
              alt="Terrace Finance"
              class="w-full rounded-lg border border-zinc-800 object-cover md:w-44 md:flex-shrink-0"
            />
            <div>
              <p class="text-sm leading-relaxed text-zinc-400">
                Delivered full-stack capabilities for a finance platform with multiple lender integrations.
              </p>
              <ul class="mt-4 space-y-2 text-sm leading-relaxed text-zinc-400">
                <li><span class="text-zinc-300">Focus:</span> user journeys, API integrations, and production-grade workflows.</li>
                <li><span class="text-zinc-300">Architecture:</span> microservice-aligned implementation in Agile sprints.</li>
                <li><span class="text-zinc-300">Delivery:</span> QA/UAT releases with consistent iteration cadence.</li>
              </ul>
              <p class="mt-3 font-mono text-xs text-zinc-500">May 2021 - Apr 2022</p>
            </div>
          </div>
        </Card>
      </div>
    </details>
  </section>
</MainLayout>
