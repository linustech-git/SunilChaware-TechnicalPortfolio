---
interface Props {
  title?: string;
  description?: string;
  className?: string;
}

const { title, description, className = "" } = Astro.props as Props;
---

<article class={`glass-card py-5 ${className}`}>
  {title && <h3 class="text-base font-semibold text-zinc-100">{title}</h3>}
  {description && <p class="mt-2 text-sm text-zinc-400">{description}</p>}
  <div class="mt-4">
    <slot />
  </div>
</article>
