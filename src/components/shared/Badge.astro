---
interface Props {
  label: string;
  tone?: "emerald" | "amber" | "neutral";
}

const { label, tone = "neutral" } = Astro.props as Props;

const tones = {
  emerald: "border-cyan-300/40 bg-cyan-300/12 text-cyan-200",
  amber: "border-amber-500/40 bg-amber-500/12 text-amber-500",
  neutral: "border-white/10 bg-white/[0.028] text-zinc-100",
};
---

<span
  class={`inline-flex items-center rounded-full border px-3 py-1 font-mono text-[11px] uppercase tracking-[0.12em] ${tones[tone]}`}
>
  {label}
</span>
