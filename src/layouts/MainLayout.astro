---
import "../styles/global.css";
import Button from "../components/shared/Button.astro";

interface TocItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  toc?: TocItem[];
}

const { title, description = "Technical whitepaper portfolio for an architect/engineer.", toc = [] } =
  Astro.props as Props;

const navItems = [
  { label: "Home", href: "/" },
  { label: "Workspace", href: "/workspace" },
  { label: "Archive", href: "/archive" },
  { label: "Lab", href: "/lab" },
];

const isPathCurrent = (href: string) =>
  href === "/" ? Astro.url.pathname === "/" : Astro.url.pathname === href || Astro.url.pathname.startsWith(`${href}/`);
const isCurrent = (href: string) => (isPathCurrent(href) ? "nav-link nav-link-active" : "nav-link");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <style>
      @keyframes grain-shift {
        0%,100% { transform: translate(0,0); }
        10%  { transform: translate(-2%,-3%); }
        30%  { transform: translate(2%, 2%); }
        50%  { transform: translate(-1%, 3%); }
        70%  { transform: translate(3%,-1%); }
        90%  { transform: translate(-3%, 1%); }
      }
      #grain-overlay {
        position: fixed; inset: -20%; width: 140%; height: 140%;
        pointer-events: none; z-index: 1;
        opacity: 0.028;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        background-size: 256px 256px;
        animation: grain-shift 0.8s steps(1) infinite;
      }
      #particle-canvas {
        position: fixed; inset: 0; pointer-events: none; z-index: 0;
      }
    </style>
  </head>
  <body class="min-h-screen text-zinc-100">
    <canvas id="particle-canvas" aria-hidden="true"></canvas>
    <div id="grain-overlay" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-[1440px] px-4 py-5 md:px-7 lg:px-10">
      <header class="sticky top-4 z-20 mb-8 rounded-lg border border-white/10 bg-zinc-950/75 px-4 py-3 shadow-2xl shadow-black/25 backdrop-blur-xl">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <a href="/" class="group inline-flex items-center gap-3 text-sm font-semibold tracking-wide text-zinc-100 hover:text-cyan-100 md:text-base">
            <span class="flex h-9 w-9 items-center justify-center rounded-lg border border-cyan-200/30 bg-cyan-200/10 font-mono text-sm text-cyan-100 shadow-lg shadow-cyan-950/20">SC</span>
            <span class="leading-tight">
              <span class="block">Sunil Chaware</span>
              <span class="block font-mono text-[0.65rem] uppercase tracking-[0.2em] text-zinc-500 group-hover:text-cyan-200/80">Technical Portfolio</span>
            </span>
          </a>
          <span class="hidden items-center gap-1.5 rounded-full border border-emerald-400/25 bg-emerald-400/10 px-2.5 py-1 font-mono text-[0.65rem] uppercase tracking-[0.15em] text-emerald-300 sm:inline-flex">
            <span class="status-dot"></span>
            Available
          </span>
          <div class="relative flex items-center gap-3">
            <button
              id="nav-toggle"
              type="button"
              aria-expanded="false"
              aria-controls="site-navigation"
              class="inline-flex h-11 w-11 items-center justify-center rounded-lg border border-white/10 bg-white/5 text-zinc-200 transition hover:border-cyan-300/50 hover:text-cyan-100 md:hidden"
            >
              <span class="sr-only">Toggle navigation</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                <path d="M4 7h16M4 12h16M4 17h16" />
              </svg>
            </button>

            <nav
              id="site-navigation"
              class="hidden min-w-full rounded-lg border border-white/10 bg-zinc-950/95 p-4 shadow-2xl backdrop-blur-xl md:flex md:min-w-0 md:rounded-none md:border-0 md:bg-transparent md:p-0 md:shadow-none"
            >
              <div class="flex flex-col gap-2 md:flex-row md:items-center md:gap-1">
                <Button
                  href="/Sunil-Chaware-CV.pdf"
                  label="Download CV"
                  variant="ghost"
                  newTab={true}
                  className="md:mr-2"
                  icon="download"
                />
                {navItems.map((item) => (
                  <a href={item.href} class={isCurrent(item.href)}>
                    {item.label}
                  </a>
                ))}
              </div>
            </nav>
          </div>
        </div>
      </header>

      <div class="grid gap-8 lg:grid-cols-[220px_minmax(0,1fr)_220px]">
        <aside class="glass-card hidden h-fit p-4 lg:sticky lg:top-24 lg:block">
          <p class="premium-kicker">Sections</p>
          <ul class="timeline-list">
            <span class="timeline-line" aria-hidden="true"></span>
            {navItems.map((item) => (
              <li class="relative">
                <a href={item.href} class={isPathCurrent(item.href) ? "step-link step-link-active" : "step-link"}>
                  <span class={isPathCurrent(item.href) ? "step-dot step-dot-active" : "step-dot"}></span>
                  <span>{item.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </aside>

        <main class="min-w-0">
          <slot />
        </main>

        <aside class="glass-card hidden h-fit self-start p-4 lg:sticky lg:top-24 lg:block">
          <p class="premium-kicker">On this page</p>
          {toc.length > 0 ? (
            <ul class="mt-3 space-y-1">
              {toc.map((item, idx) => (
                <li>
                  <a href={item.href} class={idx === 0 ? "toc-link toc-link-active" : "toc-link"}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-3 text-sm text-zinc-400">No anchors provided.</p>
          )}
        </aside>
      </div>
    </div>
    <script>
      const navToggle = document.getElementById("nav-toggle");
      const siteNavigation = document.getElementById("site-navigation");
      if (navToggle && siteNavigation) {
        navToggle.addEventListener("click", () => {
          const expanded = navToggle.getAttribute("aria-expanded") === "true";
          navToggle.setAttribute("aria-expanded", String(!expanded));
          siteNavigation.classList.toggle("hidden");
        });
      }

      /* ── Particle canvas ── */
      (function () {
        const canvas = document.getElementById("particle-canvas") as HTMLCanvasElement | null;
        if (!canvas) return;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        let W = window.innerWidth, H = window.innerHeight;
        canvas.width = W; canvas.height = H;

        window.addEventListener("resize", () => {
          W = window.innerWidth; H = window.innerHeight;
          canvas.width = W; canvas.height = H;
        });

        const N = 90;
        type Particle = { x: number; y: number; vx: number; vy: number; r: number; a: number; };
        const pts: Particle[] = Array.from({ length: N }, () => ({
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.28,
          vy: (Math.random() - 0.5) * 0.28,
          r: Math.random() * 1.2 + 0.4,
          a: Math.random() * 0.45 + 0.1,
        }));

        const MAX_DIST = 140;

        function draw() {
          if (!ctx) return;
          ctx.clearRect(0, 0, W, H);
          for (const p of pts) {
            p.x += p.vx; p.y += p.vy;
            if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
            if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(103,232,249,${p.a})`;
            ctx.fill();
          }
          for (let i = 0; i < N; i++) {
            for (let j = i + 1; j < N; j++) {
              const dx = pts[i].x - pts[j].x, dy = pts[i].y - pts[j].y;
              const d = Math.sqrt(dx * dx + dy * dy);
              if (d < MAX_DIST) {
                ctx.beginPath();
                ctx.moveTo(pts[i].x, pts[i].y);
                ctx.lineTo(pts[j].x, pts[j].y);
                ctx.strokeStyle = `rgba(103,232,249,${0.12 * (1 - d / MAX_DIST)})`;
                ctx.lineWidth = 0.6;
                ctx.stroke();
              }
            }
          }
          requestAnimationFrame(draw);
        }
        draw();
      })();
    </script>
  </body>
</html>
