---
import "../styles/global.css";

interface TocItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  toc?: TocItem[];
}

const { title, description = "Technical whitepaper portfolio for an architect/engineer.", toc = [] } =
  Astro.props as Props;

const navItems = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Workspace", href: "/workspace" },
  { label: "Archive", href: "/archive" },
  { label: "Lab", href: "/lab" },
];

const isPathCurrent = (href: string) =>
  href === "/" ? Astro.url.pathname === "/" : Astro.url.pathname === href || Astro.url.pathname.startsWith(`${href}/`);
const isCurrent = (href: string) => (isPathCurrent(href) ? "nav-link nav-link-active" : "nav-link");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen text-zinc-100">
    <div id="mouse-glow" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-[1440px] px-4 py-5 md:px-7 lg:px-10">
      <header class="sticky top-4 z-20 mb-8 rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 shadow-2xl shadow-black/20 backdrop-blur-xl">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <a href="/" class="group inline-flex items-center gap-3 text-sm font-semibold tracking-wide text-zinc-100 hover:text-orange-200 md:text-base">
            <span class="flex h-9 w-9 items-center justify-center rounded-xl border border-orange-300/30 bg-orange-400/15 font-mono text-sm text-orange-200 shadow-lg shadow-orange-950/20">SC</span>
            <span class="leading-tight">
              <span class="block">Sunil Chaware</span>
              <span class="block font-mono text-[0.65rem] uppercase tracking-[0.2em] text-zinc-500 group-hover:text-orange-300/80">Technical Portfolio</span>
            </span>
          </a>
          <div class="relative flex items-center gap-3">
            <button
              id="nav-toggle"
              type="button"
              aria-expanded="false"
              aria-controls="site-navigation"
              class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-zinc-200 transition hover:border-orange-400/50 hover:text-orange-200 md:hidden"
            >
              <span class="sr-only">Toggle navigation</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                <path d="M4 7h16M4 12h16M4 17h16" />
              </svg>
            </button>

            <nav
              id="site-navigation"
              class="hidden min-w-full rounded-2xl border border-white/10 bg-slate-950/95 p-4 shadow-2xl backdrop-blur-xl md:flex md:min-w-0 md:rounded-none md:border-0 md:bg-transparent md:p-0 md:shadow-none"
            >
              <div class="flex flex-col gap-2 md:flex-row md:items-center md:gap-1">
                {navItems.map((item) => (
                  <a href={item.href} class={isCurrent(item.href)}>
                    {item.label}
                  </a>
                ))}
              </div>
            </nav>
          </div>
        </div>
      </header>

      <div class="grid gap-8 lg:grid-cols-[220px_minmax(0,1fr)_220px]">
        <aside class="glass-card hidden h-fit p-4 lg:sticky lg:top-24 lg:block">
          <p class="premium-kicker">Sections</p>
          <ul class="timeline-list">
            <span class="timeline-line" aria-hidden="true"></span>
            {navItems.map((item) => (
              <li class="relative">
                <a href={item.href} class={isPathCurrent(item.href) ? "step-link step-link-active" : "step-link"}>
                  <span class={isPathCurrent(item.href) ? "step-dot step-dot-active" : "step-dot"}></span>
                  <span>{item.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </aside>

        <main class="min-w-0">
          <slot />
        </main>

        <aside class="glass-card hidden h-fit self-start p-4 lg:sticky lg:top-24 lg:block">
          <p class="premium-kicker">On this page</p>
          {toc.length > 0 ? (
            <ul class="mt-3 space-y-1">
              {toc.map((item, idx) => (
                <li>
                  <a href={item.href} class={idx === 0 ? "toc-link toc-link-active" : "toc-link"}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-3 text-sm text-zinc-400">No anchors provided.</p>
          )}
        </aside>
      </div>
    </div>
    <script>
      const glow = document.getElementById("mouse-glow");
      if (glow) {
        window.addEventListener("pointermove", (event) => {
          const x = event.clientX - 90;
          const y = event.clientY - 90;
          glow.style.transform = `translate(${x}px, ${y}px)`;
        });
      }

      const navToggle = document.getElementById("nav-toggle");
      const siteNavigation = document.getElementById("site-navigation");
      if (navToggle && siteNavigation) {
        navToggle.addEventListener("click", () => {
          const expanded = navToggle.getAttribute("aria-expanded") === "true";
          navToggle.setAttribute("aria-expanded", String(!expanded));
          siteNavigation.classList.toggle("hidden");
        });
      }
    </script>
  </body>
</html>
