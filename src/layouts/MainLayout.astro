---
import "../styles/global.css";

interface TocItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  toc?: TocItem[];
}

const { title, description = "Technical whitepaper portfolio for an architect/engineer.", toc = [] } =
  Astro.props as Props;

const navItems = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Workspace", href: "/workspace" },
  { label: "Archive", href: "/archive" },
  { label: "Lab", href: "/lab" },
];

const isPathCurrent = (href: string) =>
  href === "/" ? Astro.url.pathname === "/" : Astro.url.pathname === href || Astro.url.pathname.startsWith(`${href}/`);
const isCurrent = (href: string) => (isPathCurrent(href) ? "nav-link nav-link-active" : "nav-link");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen text-zinc-100">
    <div id="mouse-glow" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-[1360px] px-4 py-5 md:px-7 lg:px-10">
      <header class="sticky top-4 z-20 mb-8 border-b border-zinc-800/80 bg-black/70 px-4 py-3 backdrop-blur-sm">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <a href="/" class="text-base font-semibold tracking-wide text-orange-400 hover:text-orange-300 md:text-lg">
            Sunil Chaware - Technical Portfolio
          </a>
          <div class="relative flex items-center gap-3">
            <button
              id="nav-toggle"
              type="button"
              aria-expanded="false"
              aria-controls="site-navigation"
              class="inline-flex h-11 w-11 items-center justify-center rounded-lg border border-zinc-800 bg-zinc-950/80 text-zinc-200 transition hover:border-orange-400 hover:text-orange-300 md:hidden"
            >
              <span class="sr-only">Toggle navigation</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                <path d="M4 7h16M4 12h16M4 17h16" />
              </svg>
            </button>

            <nav
              id="site-navigation"
              class="hidden min-w-full rounded-2xl border border-zinc-800/80 bg-black/90 p-4 shadow-2xl backdrop-blur-sm md:flex md:min-w-0 md:rounded-none md:border-0 md:bg-transparent md:p-0 md:shadow-none"
            >
              <div class="flex flex-col gap-2 md:flex-row md:items-center md:gap-4">
                {navItems.map((item) => (
                  <a href={item.href} class={isCurrent(item.href)}>
                    {item.label}
                  </a>
                ))}
              </div>
            </nav>
          </div>
        </div>
      </header>

      <div class="grid gap-8 lg:grid-cols-[210px_minmax(0,1fr)_210px]">
        <aside class="hidden h-fit border-b border-zinc-800/80 p-4 lg:block">
          <p class="text-xs uppercase tracking-[0.14em] text-zinc-500">Sections</p>
          <ul class="timeline-list">
            <span class="timeline-line" aria-hidden="true"></span>
            {navItems.map((item) => (
              <li class="relative">
                <a href={item.href} class={isPathCurrent(item.href) ? "step-link step-link-active" : "step-link"}>
                  <span class={isPathCurrent(item.href) ? "step-dot step-dot-active" : "step-dot"}></span>
                  <span>{item.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </aside>

        <main class="min-w-0">
          <slot />
        </main>

        <aside class="hidden h-fit self-start border-b border-zinc-800/80 p-4 lg:sticky lg:top-24 lg:block">
          <p class="text-xs uppercase tracking-[0.14em] text-zinc-500">On this page</p>
          {toc.length > 0 ? (
            <ul class="mt-3 space-y-1">
              {toc.map((item, idx) => (
                <li>
                  <a href={item.href} class={idx === 0 ? "toc-link toc-link-active" : "toc-link"}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-3 text-sm text-zinc-400">No anchors provided.</p>
          )}
        </aside>
      </div>
    </div>
    <script>
      const glow = document.getElementById("mouse-glow");
      if (glow) {
        window.addEventListener("pointermove", (event) => {
          const x = event.clientX - 90;
          const y = event.clientY - 90;
          glow.style.transform = `translate(${x}px, ${y}px)`;
        });
      }

      const navToggle = document.getElementById("nav-toggle");
      const siteNavigation = document.getElementById("site-navigation");
      if (navToggle && siteNavigation) {
        navToggle.addEventListener("click", () => {
          const expanded = navToggle.getAttribute("aria-expanded") === "true";
          navToggle.setAttribute("aria-expanded", String(!expanded));
          siteNavigation.classList.toggle("hidden");
        });
      }
    </script>
  </body>
</html>
